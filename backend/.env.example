# ==============================================================
# Nexvia Backend — Fichier de configuration d'exemple
# ==============================================================
# INSTRUCTIONS :
#   1. Copiez ce fichier et renommez-le ".env"  (sans le .example)
#   2. Remplissez chaque variable avec vos valeurs réelles
#   3. Ne committez JAMAIS le fichier .env dans Git
# ==============================================================

# --- Serveur ---
# Port d'écoute du serveur Express en local
PORT=5000

# Environnement : development | production | test
NODE_ENV=development

# --- Sécurité JWT ---
# Clé secrète utilisée pour signer et vérifier les tokens JWT.
# OBLIGATOIRE — le serveur refuse de démarrer si cette variable est absente.
# Générez une clé forte avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum recommandé : 64 caractères aléatoires
SECRET_KEY=REMPLACEZ_PAR_UNE_CLE_FORTE_DE_64_CARACTERES_MINIMUM

# --- Base de données SQLite ---
# Chemin vers le fichier de base de données SQLite.
# En local : chemin relatif depuis le dossier backend/
# Sur Render avec disque persistant : /var/data/nexvia.db
DB_PATH=./nexvia.db

# --- CORS ---
# Origines supplémentaires autorisées (séparées par des virgules).
# Les origines localhost et GitHub Pages sont déjà incluses dans le code.
# Ajoutez ici tout domaine personnalisé supplémentaire.
# Exemple : CORS_ORIGINS=https://mon-domaine.com,https://staging.mon-domaine.com
CORS_ORIGINS=
